<Page
    x:Class="WUILiquidGlassDemo.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WUILiquidGlassDemo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="LayoutRoot" Background="#00FF3333">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Rectangle x:Name="TopDragRectangle" Grid.Row="0" Fill="{ThemeResource SystemControlAcrylicWindowBrush}" />
        <Grid Grid.Row="0" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TopElasticLeftSpace" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="TopElasticRightSpace" Width="0" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox Grid.Column="1" PlaceholderText="Type to search" QueryIcon="Find" />
        </Grid>
        <!--
        <Border Background="Blue" Width="100" Height="100" Margin="100" Grid.Row="1" />
        -->
        <Grid
            x:Name="BottomLayoutRoot"
            Grid.Row="1"
            AllowDrop="True"
            Background="White"
            DragEnter="BottomLayoutRootDragEnter"
            DragOver="BottomLayoutRootDragOver"
            Drop="BottomLayoutRootDrop">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing Width="50" Height="50" IsActive="True" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="myButton" Click="ClickHandler">Click Me</Button>
                    <Button Click="SwitchTitleBarButtonClick">Switch title bar</Button>
                    <Button Click="SwitchBackgroundTransparencyButtonClick">Switch background transparency</Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Click="AskBeforeExitButtonClick">Ask before exit</Button>
                    <Button Click="RestartAppButtonClick">Restart app</Button>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid
            x:Name="RenderSurfaceHost"
            Grid.Row="1"
            IsHitTestVisible="False"
            SizeChanged="RenderSurfaceHostSizeChanged" />
        <Grid x:Name="OverlayControlsHost" Grid.Row="1">
            <StackPanel
                Margin="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Spacing="6"
                Width="220">
                <TextBlock Text="Glass" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="Blur radius" />
                <Slider
                    x:Name="BlurRadiusSlider"
                    Maximum="16"
                    Minimum="0"
                    SmallChange="0.25"
                    StepFrequency="0.25"
                    Value="3"
                    ValueChanged="OverlaySliderValueChanged" />
                <TextBlock Text="Refraction" />
                <Slider
                    x:Name="RefractionStrengthSlider"
                    Maximum="24"
                    Minimum="0"
                    SmallChange="0.25"
                    StepFrequency="0.25"
                    Value="8"
                    ValueChanged="OverlaySliderValueChanged" />
                <TextBlock Text="Corner radius" />
                <Slider
                    x:Name="CornerRadiusSlider"
                    Maximum="96"
                    Minimum="0"
                    SmallChange="1"
                    StepFrequency="1"
                    Value="36"
                    ValueChanged="OverlaySliderValueChanged" />
                <TextBlock Text="Border thickness" />
                <Slider
                    x:Name="BorderThicknessSlider"
                    Maximum="8"
                    Minimum="0"
                    SmallChange="0.25"
                    StepFrequency="0.25"
                    Value="1.5"
                    ValueChanged="OverlaySliderValueChanged" />
                <TextBlock Text="Highlight strength" />
                <Slider
                    x:Name="HighlightStrengthSlider"
                    Maximum="2"
                    Minimum="0"
                    SmallChange="0.05"
                    StepFrequency="0.05"
                    Value="0.85"
                    ValueChanged="OverlaySliderValueChanged" />
                <TextBlock Text="Dispersion" />
                <Slider
                    x:Name="DispersionStrengthSlider"
                    Maximum="8"
                    Minimum="0"
                    SmallChange="0.1"
                    StepFrequency="0.1"
                    Value="0.8"
                    ValueChanged="OverlaySliderValueChanged" />
            </StackPanel>
            <Slider
                x:Name="YOffsetSlider"
                Width="32"
                Margin="0,24,12,56"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                IsDirectionReversed="True"
                Maximum="0"
                Orientation="Vertical"
                ValueChanged="OverlaySliderValueChanged" />
            <Slider
                x:Name="XOffsetSlider"
                Height="32"
                Margin="24,0,56,12"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                Maximum="0"
                ValueChanged="OverlaySliderValueChanged" />
        </Grid>
        <!--
        <Border x:Name="BottomBorder" Background="Blue" BorderThickness="16" BorderBrush="Red" Width="100" Height="100" Margin="100" Grid.Row="1" />
        -->
    </Grid>
</Page>
