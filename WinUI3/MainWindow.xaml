<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WUILiquidGlassDemo_WUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WUILiquidGlassDemo_WUI3"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WUILiquidGlassDemo.WUI3">

    <Grid x:Name="Root"
          Background="Transparent"
          AllowDrop="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.Resources>
            <Storyboard x:Key="DynamicSceneStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="RedOrb"
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)"
                                 From="-120"
                                 To="520"
                                 Duration="0:0:8"
                                 AutoReverse="True"
                                 EnableDependentAnimation="True" />
                <DoubleAnimation Storyboard.TargetName="RedOrb"
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)"
                                 From="0"
                                 To="90"
                                 Duration="0:0:5"
                                 AutoReverse="True"
                                 EnableDependentAnimation="True" />
                <DoubleAnimation Storyboard.TargetName="CyanOrb"
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)"
                                 From="420"
                                 To="-160"
                                 Duration="0:0:10"
                                 AutoReverse="True"
                                 EnableDependentAnimation="True" />
                <DoubleAnimation Storyboard.TargetName="CyanOrb"
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)"
                                 From="0"
                                 To="-120"
                                 Duration="0:0:6"
                                 AutoReverse="True"
                                 EnableDependentAnimation="True" />
                <DoubleAnimation Storyboard.TargetName="GoldBar"
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)"
                                 From="-260"
                                 To="260"
                                 Duration="0:0:7"
                                 AutoReverse="True"
                                 EnableDependentAnimation="True" />
                <DoubleAnimation Storyboard.TargetName="BlueBar"
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateX)"
                                 From="260"
                                 To="-260"
                                 Duration="0:0:9"
                                 AutoReverse="True"
                                 EnableDependentAnimation="True" />
                <DoubleAnimation Storyboard.TargetName="PulseRing"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.25"
                                 To="0.95"
                                 Duration="0:0:2.2"
                                 AutoReverse="True" />
                <DoubleAnimation Storyboard.TargetName="PulseRing"
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)"
                                 From="0.82"
                                 To="1.18"
                                 Duration="0:0:2.2"
                                 AutoReverse="True"
                                 EnableDependentAnimation="True" />
                <DoubleAnimation Storyboard.TargetName="PulseRing"
                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)"
                                 From="0.82"
                                 To="1.18"
                                 Duration="0:0:2.2"
                                 AutoReverse="True"
                                 EnableDependentAnimation="True" />
            </Storyboard>
        </Grid.Resources>

        <Grid Grid.ColumnSpan="2"
              Background="Transparent">
            <Image x:Name="BackgroundImage"
                   Stretch="UniformToFill"
                   Visibility="Collapsed"
                   IsHitTestVisible="False" />

            <Canvas IsHitTestVisible="False">
                <Ellipse x:Name="RedOrb"
                         Width="170"
                         Height="170"
                         Canvas.Left="72"
                         Canvas.Top="54"
                         Fill="#FFE94B5F"
                         Opacity="0.95">
                    <Ellipse.RenderTransform>
                        <CompositeTransform />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse x:Name="CyanOrb"
                         Width="220"
                         Height="220"
                         Canvas.Left="430"
                         Canvas.Top="245"
                         Fill="#FF21C7C9"
                         Opacity="0.9">
                    <Ellipse.RenderTransform>
                        <CompositeTransform />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Rectangle x:Name="GoldBar"
                           Width="760"
                           Height="44"
                           Canvas.Left="-160"
                           Canvas.Top="185"
                           Fill="#FFF2C94C"
                           Opacity="0.9"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.RenderTransform>
                        <CompositeTransform Rotation="-13" />
                    </Rectangle.RenderTransform>
                </Rectangle>

                <Rectangle x:Name="BlueBar"
                           Width="820"
                           Height="36"
                           Canvas.Left="90"
                           Canvas.Top="420"
                           Fill="#FF5A7CFF"
                           Opacity="0.78"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.RenderTransform>
                        <CompositeTransform Rotation="9" />
                    </Rectangle.RenderTransform>
                </Rectangle>

                <Ellipse x:Name="PulseRing"
                         Width="260"
                         Height="260"
                         Canvas.Left="245"
                         Canvas.Top="88"
                         Stroke="#FFE36BFF"
                         StrokeThickness="18"
                         Opacity="0.45"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <CompositeTransform />
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <ProgressRing Width="72"
                          Height="72"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="0,36,44,0"
                          IsActive="True"
                          IsHitTestVisible="False" />

            <ScrollViewer x:Name="CenterContentScroller"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Width="440"
                          Height="220"
                          Background="#CCFFFFFF"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24"
                            Spacing="10">
                    <TextBlock Text="WinUI 3 custom effect"
                               HorizontalAlignment="Center"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="EffectCaption"
                               Text="Solid translucent brush"
                               HorizontalAlignment="Center"
                               FontSize="16" />
                    <TextBlock Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer mattis ligula vitae libero volutpat, sit amet tincidunt sapien pretium."
                               TextWrapping="Wrap"
                               Margin="0,16,0,0" />
                    <TextBlock Text="Praesent euismod, erat at suscipit sagittis, augue justo suscipit lectus, vitae facilisis neque arcu vel augue. Sed commodo tellus in lorem porttitor, a mattis tortor dapibus."
                               TextWrapping="Wrap" />
                    <TextBlock Text="Donec faucibus arcu at ipsum cursus, eget tempus mi gravida. Etiam vel ante ac lorem congue feugiat. Vivamus posuere urna vitae nulla facilisis, sed fermentum ipsum luctus."
                               TextWrapping="Wrap" />
                    <TextBlock Text="Aliquam erat volutpat. Maecenas imperdiet ex vitae sem gravida, sed bibendum lorem placerat. Curabitur dignissim sem sed urna pulvinar, in tincidunt neque commodo."
                               TextWrapping="Wrap" />
                    <TextBlock Text="Suspendisse potenti. Nunc laoreet sem vel ipsum pulvinar, vitae porta justo vestibulum. Pellentesque habitant morbi tristique senectus et netus et malesuada fames."
                               TextWrapping="Wrap" />
                    <TextBlock Text="Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae; Aenean ac metus in elit vestibulum blandit."
                               TextWrapping="Wrap" />
                    <TextBlock Text="Morbi at neque sed justo efficitur consequat. Nam elementum metus eu justo blandit, vitae vulputate risus scelerisque. Nulla facilisi."
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <StackPanel.RenderTransform>
                    <TranslateTransform Y="138" />
                </StackPanel.RenderTransform>
                <Button x:Name="SetBackgroundImageButton"
                        Content="Set background image" />
                <Button x:Name="ClearBackgroundImageButton"
                        Content="Clear background image" />
            </StackPanel>
        </Grid>

        <Canvas x:Name="BackdropHost"
                Grid.ColumnSpan="2">
            <Border x:Name="BackdropFrame"
                    Canvas.Left="268"
                    Canvas.Top="80"
                    Width="420"
                    Height="260"
                    Background="Transparent"
                    BorderBrush="#FF808080"
                    BorderThickness="2">
            </Border>
        </Canvas>

        <Border Grid.Column="0">
            <StackPanel Margin="16,24,16,0" Spacing="8">
                <TextBlock Text="Brush effect"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <ComboBox x:Name="EffectSelector"
                          SelectedIndex="0"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Solid" />
                    <ComboBoxItem Content="Linear Gradient" />
                    <ComboBoxItem Content="Blur" />
                    <ComboBoxItem Content="Invert" />
                    <ComboBoxItem Content="Liquid Glass" />
                </ComboBox>
                <TextBlock Text="Border width"
                           Margin="0,12,0,0"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <Slider x:Name="BorderWidthSlider"
                        Minimum="0"
                        Maximum="24"
                        Value="2"
                        StepFrequency="1"
                        TickFrequency="4"
                        TickPlacement="BottomRight" />
                <StackPanel x:Name="LiquidGlassControls"
                            Margin="0,12,0,0"
                            Spacing="6">
                    <TextBlock Text="Liquid glass"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Gaussian blur" />
                    <Slider x:Name="GaussianBlurRadiusSlider"
                            Minimum="0"
                            Maximum="32"
                            Value="16"
                            SmallChange="0.5"
                            StepFrequency="0.5" />
                    <TextBlock Text="Blur radius" />
                    <Slider x:Name="BlurRadiusSlider"
                            Minimum="0"
                            Maximum="16"
                            Value="0"
                            SmallChange="0.25"
                            StepFrequency="0.25" />
                    <TextBlock Text="Refraction" />
                    <Slider x:Name="RefractionStrengthSlider"
                            Minimum="0"
                            Maximum="24"
                            Value="12"
                            SmallChange="0.25"
                            StepFrequency="0.25" />
                    <TextBlock Text="Corner radius" />
                    <Slider x:Name="CornerRadiusSlider"
                            Minimum="0"
                            Maximum="96"
                            Value="36"
                            SmallChange="1"
                            StepFrequency="1" />
                    <TextBlock Text="Glass border" />
                    <Slider x:Name="MaterialBorderThicknessSlider"
                            Minimum="0"
                            Maximum="8"
                            Value="1.5"
                            SmallChange="0.25"
                            StepFrequency="0.25" />
                    <TextBlock Text="Highlight" />
                    <Slider x:Name="HighlightStrengthSlider"
                            Minimum="0"
                            Maximum="2"
                            Value="0.85"
                            SmallChange="0.05"
                            StepFrequency="0.05" />
                    <TextBlock Text="Dispersion" />
                    <Slider x:Name="DispersionStrengthSlider"
                            Minimum="0"
                            Maximum="8"
                            Value="1.2"
                            SmallChange="0.1"
                            StepFrequency="0.1" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
